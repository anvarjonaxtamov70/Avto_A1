# =====================================================================
# IVY BOT — sozlamalar namunasi.
# Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring.
# ⚠️ .env ni hech qachon GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather). MAJBURIY.
BOT_TOKEN=

# Admin Telegram ID'lar (vergul bilan). Buyurtma/ro'yxat xabarlari shularga keladi.
ADMIN_IDS=1209673004,5105291033

# Mini App (do'kon) manzili — GitHub Pages.
MINI_APP_URL=https://anvarjonaxtamov70.github.io/Avto_A1/ivy_jewelry_cosmetics/

# Firebase Realtime Database URL.
FIREBASE_DB_URL=https://ivyj-6d8e4-default-rtdb.asia-southeast1.firebasedatabase.app

# Firebase Admin service account JSON fayl yo'li (profil/storis yozish uchun).
# Firebase Console -> Project Settings -> Service accounts -> Generate new private key.
# Faylni shu papkaga `serviceAccount.json` deb saqlang (ixtiyoriy — bo'lmasa suhbat baribir ishlaydi).
SERVICE_ACCOUNT_FILE=serviceAccount.json

# Bulutli hosting uchun (Render/Docker): serviceAccount.json faylni yuklab
# bo'lmagani uchun uning MATNINI shu yerga qo'ying (base64 yoki to'g'ridan-to'g'ri JSON).
# Bot ishga tushganda faylni shu matndan tiklaydi. Lokalda bu SHART EMAS.
# SERVICE_ACCOUNT_JSON=

# Groq AI kaliti (mijoz bilan AI suhbat uchun, ixtiyoriy). https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ——— Keep-alive (bulutli hosting) — odatda tegmasa ham bo'ladi ———
# Render self-ping manzilini `RENDER_EXTERNAL_URL` orqali AVTOMATIK beradi.
# Boshqa platformada to'liq manzilni qo'lda bering (mas. https://xxx.onrender.com):
# KEEP_ALIVE_URL=
# Self-ping oralig'i (soniya, default 600 = 10 daqiqa):
KEEP_ALIVE_INTERVAL=600
