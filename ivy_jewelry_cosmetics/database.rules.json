{
  "rules": {
    ".read": false,
    ".write": false,

    "admins": {
      ".read": "auth != null",
      ".write": false
    },

    "users": {
      ".read": "auth != null && (auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && (auth.uid === $uid || auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)"
      }
    },

    "products": {
      ".read": true,
      ".write": "auth != null && (auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)"
    },

    "stories": {
      ".read": true,
      ".write": "auth != null && (auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)"
    },

    "broadcasts": {
      ".read": "auth != null && (auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)",
      ".write": "auth != null && (auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)"
    },

    "reviews": {
      ".read": true,
      "$productId": {
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)"
        }
      }
    },

    "refcodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && !data.exists() && newData.val() === auth.uid"
      }
    },

    "notify_requests": {
      "$productId": {
        ".read": "auth != null && (auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)",
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === '5105291033' || auth.uid === '1209673004' || root.child('admins').child(auth.uid).val() === true)"
        }
      }
    }
  }
}
