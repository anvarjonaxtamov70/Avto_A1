# =====================================================================
#  🎵 MUSIC BOT — sozlamalar namunasi.
#  Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring.
#  .env ni HECH QACHON GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather'dan). MAJBURIY.
BOT_TOKEN=

# Default audio sifati: 128 / 192 / 320 (kbps). 320 = eng yuqori.
DEFAULT_QUALITY=320

# (Ixtiyoriy) YouTube anti-bot ("Sign in to confirm you're not a bot")
# muammosini chetlab o'tish uchun cookies fayl nomi.
# Brauzerdan eksport qilingan cookies.txt ni shu papkaga joylang.
COOKIES_FILE=cookies.txt

# (Ixtiyoriy) Self-ping manzili. Render uni RENDER_EXTERNAL_URL orqali
# avtomatik beradi, shuning uchun odatda bo'sh qoldiriladi.
# Boshqa platformada to'liq manzilni yozing (mas. https://xxx.onrender.com).
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL=600
