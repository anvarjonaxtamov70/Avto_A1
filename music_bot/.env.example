# =====================================================================
#  🎵 MUSIC BOT — sozlamalar namunasi.
#  Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring.
#  .env ni HECH QACHON GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather'dan). MAJBURIY.
BOT_TOKEN=

# Default audio sifati: 128 / 192 / 320 (kbps). 320 = eng yuqori.
DEFAULT_QUALITY=320

# (Ixtiyoriy) YouTube anti-bot ("Sign in to confirm you're not a bot")
# muammosini chetlab o'tish uchun cookies. IKKI usuldan birini tanlang:
#
# USUL 1 (TAVSIYA, Render uchun oson): cookies matnini shu yerga joylang.
#   Brauzerdan "Get cookies.txt" kengaytmasi bilan eksport qilingan
#   matnni to'liq qo'ying (bir nechta qator bo'ladi).
YT_COOKIES_CONTENT=
#
# USUL 2: cookies.txt faylini ko'rsatish (lokal yoki Render Secret File).
COOKIES_FILE=cookies.txt

# (Ixtiyoriy) Self-ping manzili. Render uni RENDER_EXTERNAL_URL orqali
# avtomatik beradi, shuning uchun odatda bo'sh qoldiriladi.
# Boshqa platformada to'liq manzilni yozing (mas. https://xxx.onrender.com).
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL=600

# (Ixtiyoriy) PO Token provider manzili. Docker ichida avtomatik 127.0.0.1:4416
# da ishlaydi — odatda o'zgartirish shart emas.
POT_PROVIDER_URL=http://127.0.0.1:4416

# (Ixtiyoriy, lekin bulutda ENG KUCHLI) Proxy orqali YouTube'ga ulanish.
# DIQQAT: bepul/datacenter proxy YouTube'da deyarli ishlamaydi — RESIDENTIAL
# proxy kerak. Format: http://user:pass@host:port  yoki  socks5://host:port
PROXY_URL=

# (Ixtiyoriy) Sinaladigan player_client tartibi (vergul bilan).
# Bo'sh qoldirilsa default: web,mweb,tv,android,ios (+ yt-dlp default).
YT_PLAYER_CLIENTS=

# (Ixtiyoriy) /diag buyrug'ini faqat shu Telegram ID egasi ishlatadi.
# Bo'sh bo'lsa — hamma ishlata oladi. O'z ID'ingizni @userinfobot dan oling.
ADMIN_ID=

# (Ixtiyoriy) /diag uchun sinov videosi (barqaror bo'lsin).
DIAG_TEST_URL=https://www.youtube.com/watch?v=dQw4w9WgXcQ
