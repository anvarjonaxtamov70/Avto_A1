<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Avto A1 - Samarkand</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #1a1a1a; color: white; margin: 0; padding: 20px; }
        .header { text-align: center; padding: 20px; background: #2d2d2d; border-radius: 15px; margin-bottom: 20px; border-bottom: 4px solid #007bff; }
        .card { background: #2d2d2d; border-radius: 15px; padding: 15px; margin-bottom: 20px; text-align: center; transition: 0.3s; }
        .price { color: #007bff; font-size: 1.4em; font-weight: bold; margin: 10px 0; }
        .btn { background: #007bff; color: white; border: none; padding: 12px 25px; border-radius: 25px; font-weight: bold; width: 100%; cursor: pointer; }
        img { width: 100%; border-radius: 10px; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Avto A1 Katalog</h1>
        <p>Sifatli ehtiyot qismlar va xizmatlar</p>
    </div>
    
    <div class="card">
        <h3>Fara Tozalash Xizmati</h3>
        <p>Professional darajada fara restavratsiyasi</p>
        <div class="price">Kelishilgan narxda</div>
        <button class="btn">Buyurtma Berish</button>
    </div>

    <div class="card">
        <h3>Zapchastlar (Gazel/Volga)</h3>
        <p>Barcha turdagi ehtiyot qismlari mavjud</p>
        <div class="price">Arzon Narxlarda</div>
        <button class="btn">Katalogdan Tanlash</button>
    </div>
</body>
</html>
