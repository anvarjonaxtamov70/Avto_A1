# =====================================================================
#  📸 Instagram Bot — Docker image
#  ffmpeg bilan (video+audio birlashtirish uchun)
# =====================================================================
FROM python:3.12-slim

# ffmpeg — yt-dlp video+audio birlashtirishi uchun
RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["python", "bot.py"]
