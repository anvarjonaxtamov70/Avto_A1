# =====================================================================
#  📸 INSTAGRAM BOT — sozlamalar namunasi.
#  Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring.
#  .env ni HECH QACHON GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather'dan). MAJBURIY.
BOT_TOKEN=

# (Ixtiyoriy) /admin buyruqlarini faqat shu ID egasi ishlata oladi.
# Bo'sh bo'lsa — hamma foydalana oladi.
ADMIN_ID=

# Instagram cookies (login talab qiladigan videolar uchun).
# Brauzerdan "Get cookies.txt" kengaytmasi bilan eksport qiling.
# USUL 1 (Render uchun oson): matnni shu yerga joylashtiring.
IG_COOKIES_CONTENT=
# USUL 2: cookies.txt faylini ko'rsatish.
IG_COOKIES_FILE=cookies.txt

# (Ixtiyoriy) Proxy — Instagram bulut IP'larni bloklaydi.
# Residential proxy tavsiya etiladi. Format: http://user:pass@host:port
PROXY_URL=

# Self-ping (Render 24/7 uchun). Render avtomatik beradi.
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL=300
