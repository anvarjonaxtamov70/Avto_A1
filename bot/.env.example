# =====================================================================
# AVTO A1 BOT — sozlamalar namunasi.
# Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring.
# .env ni HECH QACHON GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather). MAJBURIY.
BOT_TOKEN=

# Admin Telegram ID'lar (vergul bilan). Buyurtma/storis shularga ruxsat.
ADMIN_IDS=5105291033,483425630

# Mini App (do'kon) manzili — GitHub Pages.
MINI_APP_URL=https://anvarjonaxtamov70.github.io/Avto_A1/

# Cloudflare Worker manzili — storis rasm/video PROXY (DOIMIY link) va
# Telegram sendMessage uchun. Bu Worker BOT_TOKEN ni o'zida (secret) saqlaydi,
# shuning uchun storis linkida token ko'rinmaydi va link eskirmaydi.
WORKER_URL=https://avtoa1bot.anvaraxtamov70.workers.dev

# Firebase Realtime Database URL.
FIREBASE_DB_URL=https://avtoa1shop-default-rtdb.firebaseio.com

# Firebase Admin service account JSON fayl nomi (storis/profil yozish uchun).
# Firebase Console -> Project Settings -> Service accounts -> Generate new private key.
# Yuklab olingan faylni shu papkaga `serviceAccount.json` deb saqlang.
SERVICE_ACCOUNT_FILE=serviceAccount.json

# Groq AI kaliti (AI suhbat va tavsif uchun). https://console.groq.com
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


# =====================================================================
# DO'KON MA'LUMOTLARI (aloqa, manzil, ish vaqti, lokatsiya).
# Bularning hammasi BITTA manba — bot aloqa xabari, AI javoblari va
# lokatsiya shu qiymatlardan oziqlanadi (izchil ma'lumot uchun).
# Hammasi ixtiyoriy — to'ldirilmasa, pastdagi standart qiymatlar ishlatiladi.
# =====================================================================
SHOP_NAME=Avto_A1
SHOP_ADMIN=Anvar
SHOP_PHONE=+998 88 289 30 30
SHOP_TELEGRAM=@anvaraxtamov2004
SHOP_ADDRESS=Samarqand, yangi zapchast bozori, 19-sektor, 2-do'kon
SHOP_ADDRESS_RU=Самарканд, новый рынок автозапчастей, сектор 19, магазин 2
SHOP_HOURS=Har kuni 09:00–19:00
SHOP_HOURS_RU=Ежедневно 09:00–19:00

# Xaritadagi aniq joy: koordinatalarni qo'ysangiz, aloqa bo'limida jonli
# lokatsiya nuqtasi ham yuboriladi. SHOP_MAP_URL — aniq joy havolasi
# (bo'sh bo'lsa, manzil bo'yicha Google Maps qidiruv havolasi yasaladi).
SHOP_LAT=
SHOP_LNG=
SHOP_MAP_URL=
