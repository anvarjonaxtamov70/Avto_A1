# =====================================================================
# AVTO A1 BOT — sozlamalar namunasi.
# Bu faylni `.env` nomi bilan nusxalang va qiymatlarni to'ldiring.
# .env ni HECH QACHON GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather). MAJBURIY.
BOT_TOKEN=

# Admin Telegram ID'lar (vergul bilan). Buyurtma/storis shularga ruxsat.
ADMIN_IDS=5105291033,483425630

# Mini App (do'kon) manzili — GitHub Pages.
MINI_APP_URL=https://anvarjonaxtamov70.github.io/Avto_A1/

# Firebase Realtime Database URL.
FIREBASE_DB_URL=https://avtoa1shop-default-rtdb.firebaseio.com

# Firebase Admin service account JSON fayl nomi (storis/profil yozish uchun).
# Firebase Console -> Project Settings -> Service accounts -> Generate new private key.
# Yuklab olingan faylni shu papkaga `serviceAccount.json` deb saqlang.
SERVICE_ACCOUNT_FILE=serviceAccount.json

# Groq AI kaliti (AI suhbat va tavsif uchun). https://console.groq.com
GROQ_API_KEY=
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
