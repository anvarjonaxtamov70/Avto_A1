# =====================================================================
#  📖 ALBUM BOT — sozlamalar namunasi.
#  Bu faylni `.env` nomi bilan nusxalang va to'ldiring.
#  .env ni HECH QACHON GitHub'ga yuklamang (maxfiy!).
# =====================================================================

# Telegram bot tokeni (@BotFather). MAJBURIY.
BOT_TOKEN=

# Admin Telegram ID'lar (vergul bilan). Bo'sh bo'lsa — hamma rasm qo'sha oladi.
ADMIN_IDS=

# Mini App (albom) manzili — GitHub Pages.
MINI_APP_URL=https://anvarjonaxtamov70.github.io/Avto_A1/album_3d/

# Firebase Realtime Database URL (rasm ro'yxati shu yerda saqlanadi).
FIREBASE_DB_URL=

# Firebase Admin service account JSON fayl yo'li.
# Console -> Project Settings -> Service accounts -> Generate new private key.
SERVICE_ACCOUNT_FILE=serviceAccount.json

# Self-ping (Render 24/7). Render RENDER_EXTERNAL_URL ni avtomatik beradi.
KEEP_ALIVE_URL=
KEEP_ALIVE_INTERVAL=240
